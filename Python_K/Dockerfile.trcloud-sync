FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY Python_K/requirements-trcloud-sync.txt /app/requirements-trcloud-sync.txt
RUN pip install --no-cache-dir -r /app/requirements-trcloud-sync.txt

COPY Python_K /app/Python_K

WORKDIR /app/Python_K

ENTRYPOINT ["python", "trcloud_sync_runner.py"]
CMD ["--mode", "delta"]
