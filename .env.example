# Database
DATABASE_URL=postgresql://warehouse:password@localhost:5432/warehouse
DATABASE_SSL=false
DB_POOL_MAX=10

# TRCloud public/API integration
TRCLOUD_BASE_URL=https://your-company.trcloud.co
TRCLOUD_API_KEY=

# TRCloud ERP login
# Flow ครัว (Kitchen): login ด้วย user/device ที่อนุมัติแล้ว → switch จากบริษัทต้นทาง (25) เข้า company 14
#   TRCLOUD_COMPANY_ID        = 14  (บริษัทปลายทาง — ข้อมูลครัว)
#   TRCLOUD_PASSKEY           = passkey ของ company 14  (ใช้ยิง API หลัง switch)
#   TRCLOUD_ORIGIN_PASSKEY    = passkey ของ company 25  (ใช้ตอน change_company_engine.php)
# ห้าม commit ค่าจริง — เก็บใน .env local หรือ GCP Secret Manager เท่านั้น
TRCLOUD_ERP_URL=https://thaidrill.trcloud.co
TRCLOUD_COMPANY_ID=14
TRCLOUD_PASSKEY=your-company-14-passkey
TRCLOUD_ORIGIN_PASSKEY=your-company-25-passkey
TRCLOUD_USE_COMPANY_SWITCH=true
TRCLOUD_USERNAME=your-username
TRCLOUD_PASSWORD=your-password
TRCLOUD_DEVICE_ID=your-trcloud-device-cookie-id
# กรองเฉพาะโครงการที่ขึ้นต้นด้วยค่านี้ (เช่น TN → TN-658); ว่าง = ทุกโครงการ
TRCLOUD_PROJECT=TN
TRCLOUD_OUTPUT_DIR=C:\Users\You\TRCloud_Export

# Extract ranges / generated JSON paths
TRCLOUD_PO_DATE_FROM=2026-01-01
TRCLOUD_PO_DATE_TO=2026-12-31
TRCLOUD_PO_JSON_PATH=./data/po.json
TRCLOUD_PO_INCLUDE_DETAILS=true
TRCLOUD_GR_JSON_PATH=./data/gr.json
TRCLOUD_MR_JSON_PATH=./data/mr.json
TRCLOUD_INC_JSON_PATH=./data/inc.json

# TRCloud sync runner / Google Cloud
GCP_PROJECT_ID=whtdk-500801
TRCLOUD_GCS_BUCKET=kitchen-sepon-data
TRCLOUD_RELOAD_TOPIC=trcloud-snapshot-updated
TRCLOUD_DOC_TYPES=GR,MR,INC,PO
TRCLOUD_SCAN_FROM=2026-01-01
TRCLOUD_LOOKBACK_DAYS=14
TRCLOUD_FAST_WINDOW=false
TRCLOUD_REQUEST_SLEEP=0
# Local dev: ตั้ง true ถ้ายังไม่ได้รัน gcloud auth application-default login
TRCLOUD_SKIP_CLOUD=true

# API / Web
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_USE_MOCK=1
EXPO_PUBLIC_API_URL=http://localhost:3000
