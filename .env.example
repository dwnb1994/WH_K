# Database
DATABASE_URL=postgresql://warehouse:password@localhost:5432/warehouse
DATABASE_SSL=false
DB_POOL_MAX=10

# TRCloud public/API integration
TRCLOUD_BASE_URL=https://your-company.trcloud.co
TRCLOUD_API_KEY=

# TRCloud ERP login
TRCLOUD_ERP_URL=https://thaidrill.trcloud.co
TRCLOUD_COMPANY_ID=14
TRCLOUD_PASSKEY=
TRCLOUD_ORIGIN_PASSKEY=
TRCLOUD_USERNAME=
TRCLOUD_PASSWORD=
TRCLOUD_DEVICE_ID=
TRCLOUD_USE_COMPANY_SWITCH=true

# Extract ranges / generated JSON paths
TRCLOUD_PO_DATE_FROM=2026-01-01
TRCLOUD_PO_DATE_TO=2026-12-31
TRCLOUD_PO_JSON_PATH=./data/po.json
TRCLOUD_PO_INCLUDE_DETAILS=true
TRCLOUD_GR_JSON_PATH=./data/gr.json
TRCLOUD_MR_JSON_PATH=./data/mr.json
TRCLOUD_INC_JSON_PATH=./data/inc.json

# API / Web
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_USE_MOCK=1
EXPO_PUBLIC_API_URL=http://localhost:3000
