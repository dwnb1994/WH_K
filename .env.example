# ── Cloud SQL PostgreSQL ────────────────────────────────────────
# Local: postgresql://user:pass@localhost:5432/warehouse
# Cloud Run + Cloud SQL socket:
# postgresql://user:pass@/warehouse?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql://warehouse:password@localhost:5432/warehouse
DATABASE_SSL=false
DB_POOL_MAX=10

# ── TRCloud ───────────────────────────────────────────────────
TRCLOUD_BASE_URL=https://[company].trcloud.co
TRCLOUD_API_KEY=your-trcloud-api-key

# TRCloud ERP (PO/MR/GR/INC sync — cookie login)
TRCLOUD_ERP_URL=https://thaidrill.trcloud.co
TRCLOUD_COMPANY_ID=25
TRCLOUD_PASSKEY=
TRCLOUD_USERNAME=
TRCLOUD_PASSWORD=
TRCLOUD_DEVICE_ID=
TRCLOUD_PO_DATE_FROM=2026-01-01
TRCLOUD_PO_DATE_TO=2026-06-30
TRCLOUD_PO_JSON_PATH=./data/po.json
TRCLOUD_PO_INCLUDE_DETAILS=true

# ── NestJS API ────────────────────────────────────────────────
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001,https://your-domain.com

# ── Next.js Web (public) ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_USE_MOCK=1

# ── Expo Mobile (public) ──────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── Google Cloud (deploy) ─────────────────────────────────────
# GCP_PROJECT_ID=your-project
# GCP_REGION=asia-southeast1
# CLOUD_SQL_INSTANCE=your-project:asia-southeast1:warehouse-db
